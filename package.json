{
  "name": "internship-tracker",
  "version": "1.0.0",
  "description": "Polls internship sources, filters/scores, Discord alerts, and a Next.js UI",
  "private": true,
  "scripts": {
    "dev": "next dev -p ${PORT:-3001}",
    "build": "next build",
    "start": "next start -p ${PORT:-3000} -H 0.0.0.0",
    "lint": "eslint",
    "poller": "npx tsx src/poller/index.ts",
    "poller:dev": "npx tsx --watch src/poller/index.ts",
    "serve": "node scripts/supervisor.cjs",
    "test": "npx tsx src/poller/test.ts",
    "handshake:login": "npx tsx src/poller/handshake-login.ts",
    "discover:ats": "npx tsx scripts/exa-discover-ats.ts",
    "match:sparrow": "npx tsx scripts/match-sparrow-startups.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "lucide-react": "^1.7.0",
    "md5": "^2.3.0",
    "next": "16.2.1",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "tweetnacl": "^1.0.3",
    "world-countries": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/md5": "^2.3.5",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.3"
  }
}
